{
	"$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
	"productName": "wisp",
	"version": "0.1.0",
	"identifier": "com.josephembrey.wisp",
	"build": {
		"frontendDist": "../build",
		"devUrl": "http://localhost:5173",
		"beforeDevCommand": "bun run dev",
		"beforeBuildCommand": "bun run build"
	},
	"app": {
		"withGlobalTauri": true,
		"windows": [
			{
				"label": "main",
				"title": "Wisp Settings",
				"width": 400,
				"height": 520,
				"resizable": false,
				"visible": false,
				"decorations": false,
				"center": true
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	}
}
